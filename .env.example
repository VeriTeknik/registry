# Example environment configuration
# Copy to .env and modify as needed

# Registry Configuration
MCP_REGISTRY_DATABASE_URL=mongodb://mongodb:27017
MCP_REGISTRY_ENVIRONMENT=production
MCP_REGISTRY_GITHUB_CLIENT_ID=your_github_client_id
MCP_REGISTRY_GITHUB_CLIENT_SECRET=your_github_client_secret

# Stats Extension Configuration (optional)
MCP_REGISTRY_ANALYTICS_URL=http://analytics-api:8081

# Port Configuration (set to empty to disable port binding)
REGISTRY_PORT=8080:8080
MONGODB_PORT=27017:27017

# For production with Traefik, use:
# REGISTRY_PORT=
# MONGODB_PORT=